generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum CmtLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
}

enum QuizMode {
  SUBTOPIC
  CHAPTER
  CUSTOM
  FULL_TEST
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum MediaKind {
  IMAGE
  PDF
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizFlagColor {
  YELLOW
  RED
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model User {
  id             String    @id @default(cuid())
  supabaseUserId String    @unique
  email          String    @unique
  fullName       String?
  avatarUrl      String?
  role           UserRole  @default(USER)
  isPremium      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  createdNotes   Note[]    @relation("NoteCreatedBy")
  updatedNotes   Note[]    @relation("NoteUpdatedBy")
  createdQuestions Question[] @relation("QuestionCreatedBy")
  updatedQuestions Question[] @relation("QuestionUpdatedBy")
  quizAttempts   QuizAttempt[]
  mediaUploads   MediaAsset[]
  questionReports QuestionReport[]
  noteReports NoteReport[]
}

model Chapter {
  id          String      @id @default(cuid())
  level       CmtLevel
  title       String
  description String?
  chapterNo   Int         @default(0)
  isPublished Boolean     @default(false)
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subtopics   Subtopic[]
  questions  Question[]

  @@index([level, isPublished, chapterNo])
  @@index([level, isDeleted])
  @@index([level, isDeleted, chapterNo])
}

model Subtopic {
  id          String      @id @default(cuid())
  chapterId   String
  title       String
  description String?
  subtopicNo  Int         @default(0)
  isPublished Boolean     @default(false)
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  chapter     Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  notes       Note[]
  questions   Question[]

  @@index([chapterId, isPublished, subtopicNo])
  @@index([chapterId, isDeleted])
  @@index([chapterId, isDeleted, subtopicNo])
}

model Note {
  id           String      @id @default(cuid())
  subtopicId   String
  title        String
  contentJson  Json
  contentHtml  String?
  watermarkConfig Json?
  orderIndex   Int         @default(0)
  isPublished  Boolean     @default(false)
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  createdById  String?
  updatedById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  subtopic     Subtopic    @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  createdBy    User?       @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?       @relation("NoteUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  noteReports NoteReport[]

  @@index([subtopicId, isPublished, orderIndex])
  @@index([subtopicId, isDeleted])
  @@index([subtopicId, isDeleted, orderIndex])
}

model MediaAsset {
  id            String     @id @default(cuid())
  url           String
  publicId      String     @unique
  kind          MediaKind
  mimeType      String
  originalName  String
  sizeBytes     Int
  uploadedById  String?
  createdAt     DateTime   @default(now())

  uploadedBy    User?      @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([kind, createdAt])
}

model Question {
  id                String            @id @default(cuid())
  level             CmtLevel?
  chapterId         String?
  subtopicId        String?
  promptJson        Json
  explanationJson   Json?
  questionType      QuestionType      @default(SINGLE_CHOICE)
  difficulty       QuestionDifficulty?
  isPublished      Boolean           @default(false)
  isDeleted         Boolean           @default(false)
  deletedAt         DateTime?
  createdById      String?
  updatedById      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  chapter          Chapter?          @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  subtopic         Subtopic?         @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  options          QuestionOption[]
  attemptItems     QuizAttemptItem[]
  createdBy        User?             @relation("QuestionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?             @relation("QuestionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  reports          QuestionReport[]

  @@index([level, isPublished])
  @@index([level, isDeleted])
  @@index([chapterId, isPublished])
  @@index([chapterId, isDeleted])
  @@index([subtopicId, isPublished])
  @@index([subtopicId, isDeleted])
  @@index([subtopicId, isDeleted, createdAt])
  @@index([isPublished, difficulty])
  @@index([level, chapterId, isPublished])
  @@index([level, subtopicId, isPublished])
}

model QuestionOption {
  id          String    @id @default(cuid())
  questionId  String
  contentJson Json
  isCorrect   Boolean   @default(false)
  orderIndex  Int       @default(0)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedIn  QuizAttemptItem[]

  @@unique([questionId, orderIndex])
  @@index([questionId, isCorrect])
  @@index([questionId, isDeleted])
}

model QuizAttempt {
  id                 String           @id @default(cuid())
  userId             String
  mode               QuizMode
  selectionJson      Json
  level              CmtLevel?
  totalQuestions     Int
  correctCount       Int              @default(0)
  scorePercentage    Float?
  status             AttemptStatus    @default(IN_PROGRESS)
  startedAt          DateTime         @default(now())
  completedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items              QuizAttemptItem[]

  @@index([userId, startedAt])
  @@index([status, startedAt])
}

model QuizAttemptItem {
  id                     String          @id @default(cuid())
  attemptId              String
  questionId             String
  questionOrder          Int
  questionSnapshotJson   Json
  selectedOptionId       String?
  selectedOptionSnapshotJson Json?
  isCorrect              Boolean         @default(false)
  answeredAt             DateTime        @default(now())
  timeSpentSeconds       Int?
  flagColor              QuizFlagColor?
  flaggedAt              DateTime?

  attempt                QuizAttempt     @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question               Question        @relation(fields: [questionId], references: [id], onDelete: Restrict)
  selectedOption         QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@index([attemptId, questionOrder])
  @@index([attemptId, flagColor])
  @@index([attemptId, isCorrect])
  @@index([questionId])
}

model QuestionReport {
  id          String                  @id @default(cuid())
  questionId  String
  userId      String
  reason      String
  status      ReportStatus            @default(PENDING)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  question    Question                @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@unique([questionId, userId])
}

model NoteReport {
  id          String                  @id @default(cuid())
  noteId      String
  userId      String
  reason      String
  status      ReportStatus            @default(PENDING)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  note        Note                    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@unique([noteId, userId])
}
