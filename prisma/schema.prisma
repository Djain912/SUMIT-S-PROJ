generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String           @id @default(cuid())
  providerAccountId String           @unique
  email             String           @unique
  fullName          String?
  avatarUrl         String?
  role              UserRole         @default(USER)
  isPremium         Boolean          @default(false)
  premiumUntil      DateTime?
  couponRedeemed    String?
  // Freemium trial — set on first Google sign-in (see upsertOAuthUser).
  trialStartedAt    DateTime?
  trialExpiresAt    DateTime?
  subscriptionStatus SubStatus?      // TRIAL on signup, PAID on purchase/full coupon
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  passwordHash      String?
  activity          UserActivity?
  mediaUploads      MediaAsset[]
  createdNotes      Note[]           @relation("NoteCreatedBy")
  updatedNotes      Note[]           @relation("NoteUpdatedBy")
  noteReports       NoteReport[]
  createdQuestions  Question[]       @relation("QuestionCreatedBy")
  updatedQuestions  Question[]       @relation("QuestionUpdatedBy")
  questionReports   QuestionReport[]
  quizAttempts      QuizAttempt[]
  entitlements      Entitlement[]
  payments          Payment[]
  indices           Index[]
  summaryBookmarks  SummaryBookmark[]
}

// Per-user engagement counters powering the trial dashboard, conversion
// prompts, and (Phase 3) the admin funnel. 1:1 with User, created lazily.
model UserActivity {
  id                 String    @id @default(cuid())
  userId             String    @unique
  loginCount         Int       @default(0)
  lastLoginAt        DateTime?
  chaptersViewed     Json      @default("[]") // string[] of chapterIds visited
  mcqAttempted       Int       @default(0)
  mockAttempted      Int       @default(0)
  scholarUsed        Int       @default(0)
  indicatorLabUsed   Int       @default(0)
  firstChapterDoneAt DateTime?
  timeSpentSeconds   Int       @default(0)
  promptsSeen        Json      @default("[]") // string[] of dismissed conversion-prompt keys
  lastDripDay        Int?      // Phase 2: last trial-day email sent (idempotency)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubStatus {
  TRIAL
  PAID
  EXPIRED
}

// A user-saved custom stock index built in the Index Builder tool.
model Index {
  id            String         @id @default(cuid())
  userId        String
  name          String
  weightingType IndexWeighting @default(MARKET_CAP)
  constituents  Json           // string[] of stock symbols
  customWeights Json?          // optional { symbol: weight }
  chartState    Json?          // drawings, indicators, timeframe, chartType
  description   String?
  visibility    IndexVisibility @default(PRIVATE)
  shareId       String?        @unique // set when made public, used in /indices/<shareId>
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

enum IndexWeighting {
  EQUAL
  MARKET_CAP
}

enum IndexVisibility {
  PRIVATE
  PUBLIC
}

// A Razorpay payment record. Created when a checkout order is opened, then
// marked PAID once the payment is verified (via callback and/or webhook).
model Payment {
  id                String        @id @default(cuid())
  userId            String
  level             CmtLevel      @default(LEVEL_1)
  amount            Int           // in paise — the actual charged amount (after any discount)
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  razorpayOrderId   String        @unique
  razorpayPaymentId String?
  grantedUntil      DateTime?     // premium expiry granted by this payment
  couponCode        String?       // discount coupon applied at checkout
  discountPaise     Int?          // paise deducted by the coupon
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([razorpayPaymentId])
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

enum DiscountKind {
  PERCENT
  FIXED
}

// A coupon code created from the admin panel.
// Two types:
//   Free-access (days set, discountType null): grants content access for N days.
//   Price-discount (discountType set, days null): reduces checkout price.
model Coupon {
  id             String        @id @default(cuid())
  code           String        @unique
  days           Int?          // free-access coupons only; null for discount coupons
  allChapters    Boolean       @default(false)
  chapterIds     Json          @default("[]")
  isActive       Boolean       @default(true)
  maxRedemptions Int?
  redeemedCount  Int           @default(0)
  note           String?
  discountType   DiscountKind? // null = free-access; PERCENT/FIXED = price discount
  discountValue  Int?          // PERCENT: 1-90 (percentage points); FIXED: paise
  minOrderPaise  Int?          // optional minimum order amount in paise
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// A single user's access to a single chapter, granted by redeeming a coupon.
// Expires at `expiresAt`. Upserted on redemption (extends if the new expiry is later).
model Entitlement {
  id         String   @id @default(cuid())
  userId     String
  chapterId  String
  expiresAt  DateTime
  couponCode String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
}

model Chapter {
  id          String     @id @default(cuid())
  level       CmtLevel
  title       String
  slug        String
  description String?
  orderIndex  Int        @default(0)
  isPublished Boolean    @default(false)
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  // Freemium: when true, this chapter is unlocked during a user's 7-day trial.
  isTrialFree Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]
  subtopics   Subtopic[]
  entitlements Entitlement[]
  summary     ChapterSummary?

  @@unique([level, slug])
  @@index([level, isPublished, orderIndex])
  @@index([level, isDeleted])
  @@index([level, isDeleted, orderIndex])
}

model Subtopic {
  id          String     @id @default(cuid())
  chapterId   String
  title       String
  slug        String
  description String?
  orderIndex  Int        @default(0)
  isPublished Boolean    @default(false)
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  notes       Note[]
  questions   Question[]
  chapter     Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, slug])
  @@index([chapterId, isPublished, orderIndex])
  @@index([chapterId, isDeleted])
  @@index([chapterId, isDeleted, orderIndex])
}

model Note {
  id              String       @id @default(cuid())
  subtopicId      String
  title           String
  contentJson     Json
  contentHtml     String?
  watermarkConfig Json?
  orderIndex      Int          @default(0)
  isPublished     Boolean      @default(false)
  isDeleted       Boolean      @default(false)
  deletedAt       DateTime?
  createdById     String?
  updatedById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       User?        @relation("NoteCreatedBy", fields: [createdById], references: [id])
  subtopic        Subtopic     @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  updatedBy       User?        @relation("NoteUpdatedBy", fields: [updatedById], references: [id])
  noteReports     NoteReport[]

  @@index([subtopicId, isPublished, orderIndex])
  @@index([subtopicId, isDeleted])
  @@index([subtopicId, isDeleted, orderIndex])
}

model MediaAsset {
  id           String    @id @default(cuid())
  url          String
  publicId     String    @unique
  kind         MediaKind
  mimeType     String
  originalName String
  sizeBytes    Int
  uploadedById String?
  createdAt    DateTime  @default(now())
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id])

  @@index([kind, createdAt])
}

model Question {
  id              String              @id @default(cuid())
  level           CmtLevel?
  chapterId       String?
  subtopicId      String?
  promptJson      Json
  explanationJson Json?
  questionType    QuestionType        @default(SINGLE_CHOICE)
  difficulty      QuestionDifficulty?
  isPublished     Boolean             @default(false)
  isDeleted       Boolean             @default(false)
  deletedAt       DateTime?
  createdById     String?
  updatedById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  chapter         Chapter?            @relation(fields: [chapterId], references: [id])
  createdBy       User?               @relation("QuestionCreatedBy", fields: [createdById], references: [id])
  subtopic        Subtopic?           @relation(fields: [subtopicId], references: [id])
  updatedBy       User?               @relation("QuestionUpdatedBy", fields: [updatedById], references: [id])
  options         QuestionOption[]
  reports         QuestionReport[]
  attemptItems    QuizAttemptItem[]

  @@index([level, isPublished])
  @@index([level, isDeleted])
  @@index([chapterId, isPublished])
  @@index([chapterId, isDeleted])
  @@index([subtopicId, isPublished])
  @@index([subtopicId, isDeleted])
  @@index([subtopicId, isDeleted, createdAt])
  @@index([isPublished, difficulty])
  @@index([level, chapterId, isPublished])
  @@index([level, subtopicId, isPublished])
}

model QuestionOption {
  id          String            @id @default(cuid())
  questionId  String
  contentJson Json
  isCorrect   Boolean           @default(false)
  orderIndex  Int               @default(0)
  isDeleted   Boolean           @default(false)
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  question    Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedIn  QuizAttemptItem[]

  @@unique([questionId, orderIndex])
  @@index([questionId, isCorrect])
  @@index([questionId, isDeleted])
}

model QuizAttempt {
  id              String            @id @default(cuid())
  userId          String
  mode            QuizMode
  selectionJson   Json
  level           CmtLevel?
  totalQuestions  Int
  correctCount    Int               @default(0)
  scorePercentage Float?
  status          AttemptStatus     @default(IN_PROGRESS)
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           QuizAttemptItem[]

  @@index([userId, startedAt])
  @@index([status, startedAt])
  @@index([userId, level, status])
  @@index([userId, status, completedAt])
}

model QuizAttemptItem {
  id                         String          @id @default(cuid())
  attemptId                  String
  questionId                 String
  questionOrder              Int
  questionSnapshotJson       Json
  selectedOptionId           String?
  selectedOptionSnapshotJson Json?
  isCorrect                  Boolean         @default(false)
  answeredAt                 DateTime        @default(now())
  timeSpentSeconds           Int?
  flagColor                  QuizFlagColor?
  flaggedAt                  DateTime?
  attempt                    QuizAttempt     @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question                   Question        @relation(fields: [questionId], references: [id])
  selectedOption             QuestionOption? @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([attemptId, questionOrder])
  @@index([attemptId, flagColor])
  @@index([attemptId, isCorrect])
  @@index([questionId])
  @@index([answeredAt])
  @@index([attemptId, answeredAt])
}

model QuestionReport {
  id         String       @id @default(cuid())
  questionId String
  userId     String
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  question   Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model NoteReport {
  id        String       @id @default(cuid())
  noteId    String
  userId    String
  reason    String
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  note      Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId])
  @@index([status, createdAt])
  @@index([createdAt])
}

enum UserRole {
  ADMIN
  USER
}

enum CmtLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
}

enum QuizMode {
  SUBTOPIC
  CHAPTER
  CUSTOM
  FULL_TEST
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum MediaKind {
  IMAGE
  PDF
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizFlagColor {
  YELLOW
  RED
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model ContactSubmission {
  id          String              @id @default(cuid())
  fullName    String
  email       String
  mobile      String?
  subject     String
  queryType   ContactQueryType
  message     String
  status      ContactStatus       @default(NEW)
  ipAddress   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([email])
}

enum ContactQueryType {
  GENERAL
  COURSE_INFO
  TECHNICAL_SUPPORT
  BILLING
  PARTNERSHIP
  OTHER
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

// ── Bot feedback (like/dislike on AI responses) ───────────────────────────
model BotFeedback {
  id        String   @id @default(cuid())
  botType   String   // 'public' | 'study'
  question  String
  answer    String   @db.Text
  rating    String   // 'like' | 'dislike'
  userNote  String?  @db.Text // optional correction note from user
  createdAt DateTime @default(now())

  @@index([botType, rating])
  @@index([createdAt])
}

// ── Blog posts ─────────────────────────────────────────────────────────────
model BlogPost {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String    @default("")
  contentHtml   String    @default("") @db.Text
  coverImageUrl String?
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  readMinutes   Int       @default(5)
  tags          String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isPublished, publishedAt])
}

// ── Admin-written Q&A corrections (injected as mandatory facts into both bots) ──
model BotQAPair {
  id        String   @id @default(cuid())
  botType   String   // 'public' | 'study'
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([botType])
}

// ── FII/DII permanent daily log ───────────────────────────────────────────
// Cash segment: one row per trading day, upserted by the 6:30 PM IST cron.
model FiiDiiLog {
  date      String   @id             // YYYY-MM-DD
  fiiBuy    Float
  fiiSell   Float
  fiiNet    Float
  diiBuy    Float
  diiSell   Float
  diiNet    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// F&O participant open interest: one row per trading day.
model FnoLog {
  date            String   @id       // DD-Mon-YYYY (NSE archive format)
  fiiIdxFutLong   Float    @default(0)
  fiiIdxFutShort  Float    @default(0)
  fiiStkFutLong   Float    @default(0)
  fiiStkFutShort  Float    @default(0)
  fiiIdxCallLong  Float    @default(0)
  fiiIdxCallShort Float    @default(0)
  fiiIdxPutLong   Float    @default(0)
  fiiIdxPutShort  Float    @default(0)
  diiIdxFutLong   Float    @default(0)
  diiIdxFutShort  Float    @default(0)
  diiStkFutLong   Float    @default(0)
  diiStkFutShort  Float    @default(0)
  diiIdxCallLong  Float    @default(0)
  diiIdxCallShort Float    @default(0)
  diiIdxPutLong   Float    @default(0)
  diiIdxPutShort  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
}

// ── Chapter Quick Revision (6-section summary) ───────────────────────────────
// One revision sheet per chapter, authored by admin (often AI-drafted), read by students.
model ChapterSummary {
  id          String   @id @default(cuid())
  chapterId   String   @unique
  summary     Json     @default("[]")   // string[] — Chapter Summary bullets
  keyConcepts Json     @default("[]")   // { name, definition, whyItMatters, examAngle }[]
  formulas    Json     @default("[]")   // { label, expression, notes }[]
  examTips    Json     @default("[]")   // { remember, mistake }[]
  highYield   Json     @default("[]")   // string[] — High-Yield Facts
  oneMinute   Json     @default("[]")   // string[] — One-Minute Revision
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId, isPublished])
}

model SummaryBookmark {
  id        String   @id @default(cuid())
  userId    String
  chapterId String
  itemType  String   // 'keyPoint' | 'examTip' | 'formula'
  itemIndex Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId, itemType, itemIndex])
  @@index([userId, chapterId])
}

// ── Homepage public chatbot knowledge sources ──────────────────────────────
model PublicBotSource {
  id        String   @id @default(cuid())
  type      String   // 'pdf' | 'url'
  name      String   // filename or URL
  content   String   @db.Text
  charCount Int
  createdAt DateTime @default(now())

  @@index([createdAt])
}
