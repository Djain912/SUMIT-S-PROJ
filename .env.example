# Database (Supabase Postgres)
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Cloudinary (add your own)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# reCAPTCHA (add your own)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# App
# Use http://localhost:3000 locally and https://chartix.in in production after the domain is connected.
NEXT_PUBLIC_SITE_URL="https://chartix.in"
NEXTAUTH_URL="https://chartix.in"
ALLOWED_ORIGINS="https://chartix.in,https://www.chartix.in"
SUPER_ADMIN_EMAIL="admin@chartix.com"
SUPABASE_SERVICE_ROLE_KEY=""

# Next.js SWC fallback for Windows environments that block the native addon
NEXT_TEST_WASM_DIR="node_modules/next/wasm/@next/swc-wasm-nodejs"
